<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer circle background -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#6B7BA4"/>
            <size android:width="120dp" android:height="120dp"/>
        </shape>
    </item>

    <!-- Inner circle -->
    <item
        android:top="20dp"
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp">
        <shape android:shape="oval">
            <solid android:color="#1C3150"/>
            <size android:width="80dp" android:height="80dp"/>
        </shape>
    </item>

    <!-- Center dot -->
    <item
        android:top="48dp"
        android:bottom="48dp"
        android:left="48dp"
        android:right="48dp">
        <shape android:shape="oval">
            <solid android:color="#A8BDB0"/>
        </shape>
    </item>

</layer-list>